  "homepage": "https://github.com/JakeLabate/Claude-SEO-Skills#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JakeLabate/Claude-SEO-Skills.git"
  },
  "bugs": {
    "url": "https://github.com/JakeLabate/Claude-SEO-Skills/issues"
  },
  "engines": {
    "node": ">=16.7.0"
  }
}
